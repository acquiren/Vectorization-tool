  <property name="styleSheet">
   <string notr="true">/* 全局样式 - 极简高级设计 */
QMainWindow {
    background-color: #F7F7F8;
    font-size: 28px;
}

/* 分割器 (QSplitter) 样式 - 悬停时显示拖拽条 */
QSplitter::handle {
    background-color: transparent;
    width: 12px;
    margin: 0px 4px;
    border-radius: 6px;
}
QSplitter::handle:hover {
    background-color: #E5E5EA;
}
QSplitter::handle:pressed {
    background-color: #D1D1D6;
}

/* 选项卡样式 - 扁平无边框设计 */
QTabWidget::pane {
    border: 1px solid #E5E5EA;
    background-color: #FFFFFF;
    border-radius: 8px;
    padding: 12px;
}

QTabBar::tab {
    background-color: transparent;
    color: #8E8E93;
    padding: 12px 24px;
    margin-right: 4px;
    font-size: 28px;
    font-weight: 500;
    border: none;
    min-width: 180px;
    border-bottom: 2px solid transparent;
}

QTabBar::tab:selected {
    color: #1C1C1E;
    border-bottom: 2px solid #1C1C1E;
}

QTabBar::tab:hover:!selected {
    color: #3A3A3C;
}

/* 按钮样式 - 极简深色按钮 */
QPushButton {
    background-color: #1C1C1E;
    color: #FFFFFF;
    border: none;
    padding: 14px 28px;
    border-radius: 6px;
    font-size: 28px;
    font-weight: 500;
    min-height: 50px;
}

QPushButton:hover {
    background-color: #2C2C2E;
}

QPushButton:pressed {
    background-color: #000000;
}

QPushButton:disabled {
    background-color: #E5E5EA;
    color: #8E8E93;
}

/* 次要按钮样式 - 导入按钮 (线框风格) */
QPushButton#btn_import {
    background-color: #FFFFFF;
    color: #1C1C1E;
    border: 1px solid #D1D1D6;
}

QPushButton#btn_import:hover {
    background-color: #F2F2F7;
}

QPushButton#btn_import:pressed {
    background-color: #E5E5EA;
}

/* 高级设置页 - 与导入按钮同款的次要按钮 */
QPushButton#btn_import_advanced {
    background-color: #FFFFFF;
    color: #1C1C1E;
    border: 1px solid #D1D1D6;
}

QPushButton#btn_import_advanced:hover {
    background-color: #F2F2F7;
}

QPushButton#btn_import_advanced:pressed {
    background-color: #E5E5EA;
}

/* 输入框样式 - 干净的边框 */
QSpinBox, QDoubleSpinBox {
    padding: 8px;
    border: 1px solid #D1D1D6;
    border-radius: 6px;
    background-color: #FFFFFF;
    font-size: 28px;
    color: #1C1C1E;
    min-width: 90px;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #1C1C1E;
}

QSpinBox:disabled, QDoubleSpinBox:disabled {
    background-color: #F2F2F7;
    color: #8E8E93;
}

/* 下拉框 - 与 QSpinBox 一致的边框与字号 */
QComboBox {
    padding: 8px 12px;
    border: 1px solid #D1D1D6;
    border-radius: 6px;
    background-color: #FFFFFF;
    font-size: 28px;
    color: #1C1C1E;
    min-height: 50px;
}

QComboBox:hover {
    border: 1px solid #8E8E93;
}

QComboBox:focus {
    border: 1px solid #1C1C1E;
}

QComboBox:disabled {
    background-color: #F2F2F7;
    color: #8E8E93;
}

QComboBox::drop-down {
    border: none;
    width: 44px;
    border-left: 1px solid #E5E5EA;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
}

QComboBox::down-arrow {
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 8px solid #1C1C1E;
    margin-right: 14px;
}

QComboBox QAbstractItemView {
    font-size: 28px;
    color: #1C1C1E;
    background-color: #FFFFFF;
    border: 1px solid #E5E5EA;
    border-radius: 6px;
    padding: 8px;
    selection-background-color: #F2F2F7;
    selection-color: #1C1C1E;
}

/* 滑块样式 - 极细轨道 */
QSlider::groove:horizontal {
    height: 4px;
    background-color: #E5E5EA;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background-color: #1C1C1E;
    width: 16px;
    margin: -6px 0;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    background-color: #3A3A3C;
}

QSlider:disabled {
    background: #F2F2F7;
}

QSlider::handle:horizontal:disabled {
    background-color: #C7C7CC;
}

/* 标签样式 */
QLabel {
    color: #1C1C1E;
    font-size: 28px;
}

/* 分组框样式 - 弱化边框 */
QGroupBox {
    font-weight: 500;
    font-size: 28px;
    border: 1px solid #E5E5EA;
    border-radius: 8px;
    margin-top: 24px;
    padding-top: 16px;
    background-color: #FFFFFF;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 16px;
    padding: 0 8px;
    color: #1C1C1E;
}

QGroupBox:disabled {
    color: #8E8E93;
    background-color: #F2F2F7;
}

QGroupBox:disabled::title {
    color: #8E8E93;
}

/* 复选框样式 */
QCheckBox {
    font-size: 28px;
    font-weight: 500;
    spacing: 10px;
    color: #1C1C1E;
}

QCheckBox::indicator {
    width: 22px;
    height: 22px;
    border: 1px solid #D1D1D6;
    border-radius: 4px;
    background-color: #FFFFFF;
}

QCheckBox::indicator:hover {
    border: 1px solid #1C1C1E;
}

QCheckBox::indicator:checked {
    background-color: #1C1C1E;
    border-color: #1C1C1E;
    image: url(data:image/svg+xml;base64,);
}

QCheckBox::indicator:disabled {
    background-color: #F2F2F7;
    border-color: #E5E5EA;
}

/* 滚动区域及预览区样式 */
QScrollArea {
    border: 1px solid #E5E5EA;
    border-radius: 8px;
    background-color: #F9F9F9;
}

QLabel#lbl_preview_input, QLabel#lbl_preview_output {
    background-color: transparent;
    border: 1px dashed #D1D1D6;
    border-radius: 8px;
    font-size: 28px;
    color: #8E8E93;
}

/* 菜单栏及状态栏 */
QMenuBar {
    font-size: 28px;
    padding: 4px;
    background-color: #FFFFFF;
    border-bottom: 1px solid #E5E5EA;
}

QMenuBar::item {
    padding: 8px 16px;
    background-color: transparent;
    border-radius: 4px;
    color: #1C1C1E;
}

QMenuBar::item:selected {
    background-color: #F2F2F7;
    color: #1C1C1E;
}

QMenu {
    font-size: 28px;
    padding: 6px;
    background-color: #FFFFFF;
    border: 1px solid #E5E5EA;
    border-radius: 6px;
}

QMenu::item {
    padding: 8px 32px;
    border-radius: 4px;
    color: #1C1C1E;
}

QMenu::item:selected {
    background-color: #F2F2F7;
    color: #1C1C1E;
}

QStatusBar {
    font-size: 26px;
    padding: 6px;
    background-color: #FFFFFF;
    border-top: 1px solid #E5E5EA;
    color: #8E8E93;
}</string>
